<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Power BI RLS Chatbot</title>
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/powerbi-client@2.23.1/dist/powerbi.min.js"></script>
</head>
<body>

    <!-- ========================= TOP BAR ========================= -->
    <header class="topbar">
        <h1>
            <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
            Power BI RLS Chatbot
        </h1>
        <div class="user-selector">
            <label for="userSelect">User:</label>
            <select id="userSelect">
                <option value="">— Select a user —</option>
                <% demo_users.each do |display_name, rls_username| %>
                <option value="<%= rls_username %>"><%= display_name %></option>
                <% end %>
            </select>
            <span class="user-badge" id="rlsTag">
                <span class="dot"></span>
            </span>
        </div>
    </header>

    <!-- ========================= MAIN ========================= -->
    <main class="main-container">
        <!-- Report Panel -->
        <section class="report-panel">
            <div class="panel-header">
                <span>Report</span>
                <span class="rls-tag" id="rlsTagReport"></span>
            </div>
            <div id="reportContainer">
                <div class="placeholder-msg">
                    <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z"/></svg>
                    <p>Select a user to load the report</p>
                </div>
            </div>
        </section>

        <!-- Chat Panel -->
        <section class="chat-panel">
            <div class="panel-header">
                <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                Data Chatbot
            </div>
            <div class="chat-messages" id="chatMessages">
                <div class="placeholder-msg">
                    <p>Select a user to start chatting.</p>
                </div>
            </div>
            <div class="chat-input-bar">
                <input type="text"
                       id="chatInput"
                       placeholder="Ask a question about your data…"
                       autocomplete="off" />
                <button id="sendBtn">
                    Send
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                    </svg>
                </button>
            </div>
        </section>
    </main>

    <script src="/js/app.js"></script>
</body>
</html>